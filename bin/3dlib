#!/usr/bin/perl
use v5.40;
use experimental qw(class refaliasing declared_refs);
use utf8;
use FindBin;
use lib "$FindBin::RealBin/../lib";
use File::Path qw(make_path);
use Getopt::Long qw(GetOptionsFromArray);

use LibConfig;
use DB;
use Util qw(fmt_time human_size dry_print decode_argv text_for_db);
use Import;
use Delete;
use Meta;
use Thumbs;
use Run;
use Web;
use Item ();
use Translate;

binmode STDOUT, ':encoding(UTF-8)';
binmode STDERR, ':encoding(UTF-8)';

# ARGV paths/names arrive as filesystem bytes — decode to real Unicode early
@ARGV = decode_argv(@ARGV);

# Fail loudly on unknown options; do not pass them through as bare args.
Getopt::Long::Configure(qw(
  no_ignore_case
  bundling
  no_auto_abbrev
  no_pass_through
  no_getopt_compat
));

my $cmd = shift @ARGV // 'help';
$cmd = 'help' if $cmd eq '-h' || $cmd eq '--help';

my %cmds = (
  init              => \&cmd_init,
  import            => \&cmd_import,
  delete            => \&cmd_delete,
  rm                => \&cmd_delete,
  edit              => \&cmd_edit,
  tag               => \&cmd_tag,
  tags              => \&cmd_tag,
  keyword           => \&cmd_tag,
  keywords          => \&cmd_tag,
  scan              => \&cmd_scan,
  query             => \&cmd_query,
  search            => \&cmd_query,
  ls                => \&cmd_ls,
  list              => \&cmd_ls,
  describe          => \&cmd_describe,
  show              => \&cmd_show,
  inspect           => \&cmd_show,
  view              => \&cmd_show,
  thumbs            => \&cmd_thumbs,
  stats             => \&cmd_stats,
  run               => \&cmd_run,
  open              => \&cmd_run,
  serve             => \&cmd_serve,
  'install-handler' => \&cmd_install_handler,
  handler           => \&cmd_install_handler,
  'repair-encoding' => \&cmd_repair_encoding,
  translate         => \&cmd_translate,
  help              => \&cmd_help,
);

# Primary command names + one-line summary (aliases omitted; help is sorted).
my @COMMAND_HELP = (
  [ 'delete',           'Remove catalog entry (and files under /share/3d)' ],
  [ 'describe',         'Show one item in detail' ],
  [ 'edit',             'Update catalog metadata (URL, description, name, …)' ],
  [ 'help',             'This help, or subcommand help' ],
  [ 'tag',              'Add/remove/list keywords (tags) on items' ],
  [ 'import',           'Import file/dir/zip into /share/3d' ],
  [ 'init',             'Create library dirs + empty database' ],
  [ 'install-handler',  'Register bambustudio:// and freecad:// handlers' ],
  [ 'ls',               'List items' ],
  [ 'query',            'Full-text search' ],
  [ 'repair-encoding',  'Fix UTF-8 mojibake in catalog fields' ],
  [ 'run',              'Import (optional) + open in Bambu Studio' ],
  [ 'scan',             'Catalog files already under /share/3d' ],
  [ 'serve',            'Web UI on port 31353' ],
  [ 'show',             'Describe item and open its thumbnail (feh, configurable)' ],
  [ 'stats',            'Counts and coverage' ],
  [ 'thumbs',           'Generate missing thumbs (3MF / photos / mesh-preview)' ],
  [ 'translate',        'Translate non-English names/descriptions via OpenAI/Grok API' ],
);

if (!$cmds{$cmd}) {
  # Allow: 3dlib bambustudio://... freecad://... https://... or /path
  if ($cmd =~ m{^(bambustudio:|freecad:|3dlib:|https?://|/|\.)}i || -e $cmd) {
    unshift @ARGV, $cmd;
    $cmd = 'run';
  }
  else {
    warn "Unknown command: $cmd\n";
    cmd_help();
    exit 2;
  }
}

$cmds{$cmd}->(@ARGV);
exit 0;

# ---------------------------------------------------------------------------
# Option parsing: --help prints usage and exits 0; unknown options abort
# without running the command.
# ---------------------------------------------------------------------------

sub parse_opts {
  my ($usage, $args_ref, @spec) = @_;
  my $help = 0;

  # Turn Getopt::Long warnings (unknown option: ...) into hard failures
  my @warnings;
  local $SIG{__WARN__} = sub {
    my ($msg) = @_;
    if ($msg =~ /Unknown option/i) {
      push @warnings, $msg;
      return;
    }
    warn $msg;
  };

  my $ok = GetOptionsFromArray($args_ref, 'help|h' => \$help, @spec);

  if ($help) {
    print $usage;  # usage text already ends with newline
    exit 0;
  }

  if (@warnings || !$ok) {
    for my $w (@warnings) {
      say STDERR $w;
    }
    say STDERR "Error: invalid option(s). Nothing done.";
    say STDERR $usage;
    exit 2;
  }

  # Anything left that looks like an option was not accepted
  for my $a (@$args_ref) {
    if ($a =~ /^--\w/ || ($a =~ /^-\w/ && $a ne '-')) {
      say STDERR "Error: unexpected option '$a'. Nothing done.";
      say STDERR $usage;
      exit 2;
    }
  }

  return;
}


sub ensure_db {
  DB::db_connect(LibConfig::db_path());
  DB::init_schema();
}

sub cmd_init {
  my @args = @_;
  my $usage = <<'USAGE';
Usage: 3dlib init

  Create /share/3d directory layout, config, and empty SQLite database.
  Safe to re-run (directories and schema are created if missing).

Options:
  -h, --help    Show this help
USAGE
  parse_opts($usage, \@args);
  die "Error: unexpected argument(s): @args\n" if @args;

  my $root = LibConfig::library_root();
  for my $d (
    $root,
    "$root/.library",
    "$root/.thumbs",
    "$root/projects",
    "$root/stl",
    "$root/3mf",
    "$root/step",
    "$root/fcstd",
    "$root/inbox",
  ) {
    make_path($d);
    say "ok $d";
  }
  my $cfg = LibConfig::load_config();
  $cfg->{library_root} = $root;
  LibConfig::save_config($cfg);
  ensure_db();
  say "Database: ", LibConfig::db_path();
  say "3dlib initialized.";
}

sub cmd_import {
  my @args = @_;
  my ($dryrun, $move, $copy, $clean, $quiet, $source_url);
  my $usage = <<'USAGE';
Usage: 3dlib import PATH [options]

  Import a model file, project directory, or zip into /share/3d.
  Default is to MOVE the source into the library.
  Prints a detailed summary per item unless --quiet is given.

  Zip handling:
    - Zip containing 3D models (stl/step/3mf/…) → unpack into projects/,
      flatten a single top-level folder, catalog, optional URL file.
    - Zip with no model files → move intact to download_dir
      (default /share/tmp; config download_dir / THREEDLIB_DOWNLOAD_DIR).

Options:
  --clean               After success: remove source (with --copy) or
                        empty leftover dirs (with --move on directories)
  --copy                Copy into library; leave source in place
  --dryrun, --dry-run   Describe actions only; do not change files
  --move                Move into library (default)
  --source-url URL      Primary page URL for this import (canonicalized
                        for MakerWorld/CDN forms). Sets catalog primary
                        and writes/updates a project URL file.
  -q, --quiet           One-line results only (no per-item detail)
  -h, --help            Show this help

PATH:
  Single 3D file (.3mf .stl .step .fcstd ...) or a .zip
  Directory: only 3D files / project-like subdirs / zips are imported
USAGE
  parse_opts(
    $usage, \@args,
    'dryrun|dry-run' => \$dryrun,
    'move!'          => \$move,
    'copy!'          => \$copy,
    'clean'          => \$clean,
    'quiet|q'        => \$quiet,
    'source-url=s'   => \$source_url,
  );

  my $path = shift @args
    // die "Error: PATH required.\nTry: 3dlib import --help\n";
  die "Error: unexpected argument(s): @args\n" if @args;

  my $do_copy = 0;
  if (defined $copy && $copy) {
    $do_copy = 1;
  }
  elsif (defined $move && !$move) {
    $do_copy = 1;
  }

  ensure_db();
  my %imp = (
    path   => $path,
    dryrun => $dryrun ? 1 : 0,
    copy   => $do_copy,
    clean  => $clean ? 1 : 0,
  );
  $imp{source_url} = $source_url if defined $source_url && length $source_url;
  my $res = Import::import_path(%imp);
  _print_results($res, quiet => $quiet ? 1 : 0);
}

sub cmd_delete {
  my @args = @_;
  my ($dryrun, $keep_files);
  my $usage = <<'USAGE';
Usage: 3dlib delete ID|PATH|latest[-N]... [options]
       3dlib rm     ID|PATH|latest[-N]... [options]

  Remove one or more items from the catalog.  By default also deletes the
  corresponding files under /share/3d (and the thumbnail).  Paths outside the
  library root are refused unless --keep-files is used.

Options:
  --dryrun, --dry-run   Show what would be removed; change nothing
  --keep-files          Catalog entry and thumb only; leave model files
  -h, --help            Show this help
USAGE
  parse_opts(
    $usage, \@args,
    'dryrun|dry-run' => \$dryrun,
    'keep-files'     => \$keep_files,
  );
  die "Error: ID or PATH required.\nTry: 3dlib delete --help\n" unless @args;

  ensure_db();
  my $res = Delete::delete_items(
    targets    => \@args,
    dryrun     => $dryrun ? 1 : 0,
    keep_files => $keep_files ? 1 : 0,
  );
  say scalar($res->@*), " item(s) processed";
}

sub cmd_edit {
  my @args = @_;
  my (
    $dryrun, $name, $description, $description_orig, $status,
    $url, $clear_url, $clear_urls, $source_site, $source_id, $design_model_id,
    $auto_from_url, $tags, $clear_tags,
  );
  my (@add_urls, @add_tags, @remove_tags);
  my $usage = <<'USAGE';
Usage: 3dlib edit ID|PATH|latest[-N] [options]

  Update catalog metadata for one item (does not rename or move files).
  Only fields you pass are changed; omitted fields stay as they are.

Examples:
  3dlib edit 9 --url 'https://makerworld.com/en/models/935041'
  3dlib edit 9 --add-url 'https://printables.com/model/123' --status active
  3dlib edit 9 --description 'Short note' --name 'Better name'
  3dlib edit 9 --tag clasp --tag jewelry
  3dlib edit 9 --tags clasp,jewelry
  3dlib edit 9 --description=@notes.txt
  3dlib edit 9 --clear-urls --dryrun

Options:
  --add-tag TAG              Add keyword/tag (repeatable)
  --add-url URL              Append an additional source URL (repeatable)
  --auto-from-url            Fill empty site/ids from --url (default when --url set)
  --clear-tags               Remove all keywords/tags
  --clear-url                Clear primary source URL
  --clear-urls               Clear primary + additional URLs and related site ids
  --description TEXT         Set description (@file or - for stdin)
  --description-orig TEXT    Set original/CJK description (@file or -)
  --design-model-id ID       MakerWorld DesignModelId
  --dryrun, --dry-run        Show changes only
  --name TEXT                Display name
  --no-auto-from-url         Do not infer site/ids from URL
  --remove-tag TAG           Remove keyword/tag (repeatable)
  --source-id ID             Site-specific id
  --source-site NAME         e.g. makerworld, printables
  --status TEXT              e.g. active, hidden, archived, unsorted
  --tag TAG                  Same as --add-tag (repeatable)
  --tags LIST                Replace all tags (comma-separated)
  --url URL                  Primary source URL
  -h, --help                 Show this help
USAGE
  parse_opts(
    $usage, \@args,
    'dryrun|dry-run'       => \$dryrun,
    'name=s'               => \$name,
    'description=s'        => \$description,
    'description-orig=s'   => \$description_orig,
    'status=s'             => \$status,
    'url=s'                => \$url,
    'add-url=s'            => \@add_urls,
    'clear-url'            => \$clear_url,
    'clear-urls'           => \$clear_urls,
    'source-site=s'        => \$source_site,
    'source-id=s'          => \$source_id,
    'design-model-id=s'    => \$design_model_id,
    'auto-from-url!'       => \$auto_from_url,
    'tag|add-tag=s'        => \@add_tags,
    'remove-tag=s'         => \@remove_tags,
    'tags=s'               => \$tags,
    'clear-tags'           => \$clear_tags,
  );

  my $target = shift @args
    // die "Error: ID or PATH required.\nTry: 3dlib edit --help\n";
  die "Error: unexpected argument(s): @args\n" if @args;

  my %fields;
  $fields{name}             = $name             if defined $name;
  $fields{description}      = _read_text_opt($description)      if defined $description;
  $fields{description_orig} = _read_text_opt($description_orig) if defined $description_orig;
  $fields{status}           = $status           if defined $status;
  $fields{source_url}       = $url              if defined $url;
  $fields{source_site}      = $source_site      if defined $source_site;
  $fields{source_id}        = $source_id        if defined $source_id;
  $fields{design_model_id}  = $design_model_id  if defined $design_model_id;
  $fields{add_urls}         = \@add_urls        if @add_urls;
  $fields{clear_url}        = 1                 if $clear_url;
  $fields{clear_urls}       = 1                 if $clear_urls;
  $fields{clear_tags}       = 1                 if $clear_tags;
  $fields{tags_set}         = $tags             if defined $tags;
  $fields{tags_add}         = \@add_tags        if @add_tags;
  $fields{tags_remove}      = \@remove_tags     if @remove_tags;

  if (defined $auto_from_url) {
    $fields{auto_from_url} = $auto_from_url ? 1 : 0;
  }

  unless (
       defined $name || defined $description || defined $description_orig
    || defined $status || defined $url || @add_urls
    || $clear_url || $clear_urls || $clear_tags
    || defined $source_site || defined $source_id || defined $design_model_id
    || defined $tags || @add_tags || @remove_tags
  ) {
    die "Error: nothing to change (pass --url, --description, --tag, …).\nTry: 3dlib edit --help\n";
  }

  ensure_db();
  my $res = Item::edit(
    target => $target,
    dryrun => $dryrun ? 1 : 0,
    %fields,
  );

  if ($res->{noop}) {
    say "No changes for #$res->{id} $res->{name}";
    return;
  }

  my $prefix = $res->{dryrun} ? 'would set' : 'set';
  say(($res->{dryrun} ? 'dryrun ' : '') . "#$res->{id} $res->{name}");
  for my $k (sort keys $res->{changes}->%*) {
    my $ch   = $res->{changes}{$k};
    my $old  = $ch->{old} // '';
    my $new  = $ch->{new} // '';
    $old =~ s/\n/\\n/g;
    $new =~ s/\n/\\n/g;
    if (length($old) > 80) { $old = substr($old, 0, 77) . '...' }
    if (length($new) > 80) { $new = substr($new, 0, 77) . '...' }
    say "  $prefix $k:";
    say "    - $old" if length $old;
    say "    + $new" if length $new;
    say "    + (cleared)" if !length $new && length $old;
  }
}

sub cmd_tag {
  my @args = @_;
  my ($list, $clear, $dryrun);
  my (@add, @remove);
  my $usage = <<'USAGE';
Usage: 3dlib tag [ID|PATH] [TAG]... [options]
       3dlib tags
       3dlib keyword ...

  Catalog keywords/tags (not from Bambu 3MF — those files have no keyword
  field).  Apply to any item type (3mf, stl, projects, …).

  With no ID: list all tags and counts.
  With ID and TAG args: add those tags (default).

Examples:
  3dlib tag 9 clasp jewelry
  3dlib tag 9 --add clasp --add jewelry
  3dlib tag 9 --remove clasp
  3dlib tag 9 --clear
  3dlib tag 9 --set clasp,jewelry
  3dlib tags
  3dlib ls --tag clasp

Options:
  --add TAG             Add tag (repeatable)
  --clear               Remove all tags from the item
  --dryrun, --dry-run   Show changes only
  --list                List all tags (default when no ID)
  --remove TAG          Remove tag (repeatable)
  --set LIST            Replace all tags (comma-separated)
  -h, --help            Show this help
USAGE
  my $set;
  parse_opts(
    $usage, \@args,
    'list'             => \$list,
    'add=s'            => \@add,
    'remove=s'         => \@remove,
    'clear'            => \$clear,
    'set=s'            => \$set,
    'dryrun|dry-run'   => \$dryrun,
  );

  # Bare "3dlib tags" or --list
  if ($list || !@args) {
    ensure_db();
    my $rows = DB::list_tags();
    if (!$rows->@*) {
      say "No tags yet. Add some with: 3dlib tag ID clasp";
      return;
    }
    for my $r ($rows->@*) {
      printf "%5d  %s\n", $r->{count}, $r->{tag};
    }
    say scalar($rows->@*), " tag(s)";
    return;
  }

  my $target = shift @args;
  # Remaining bare args are tags to add
  push @add, @args if @args;

  ensure_db();
  my %fields = (target => $target, dryrun => $dryrun ? 1 : 0);
  $fields{clear_tags}  = 1 if $clear;
  $fields{tags_set}    = $set if defined $set;
  $fields{tags_add}    = \@add if @add;
  $fields{tags_remove} = \@remove if @remove;

  unless ($clear || defined $set || @add || @remove) {
    # No change ops: show current tags for the item
    my $item = Item::load($target) // die "Not found: $target\n";
    my $tags = DB::get_item_tags($item->id);
    say "#", $item->id, " ", $item->name;
    say "tags: ", ($tags->@* ? join(', ', $tags->@*) : '(none)');
    return;
  }

  my $res = Item::edit(%fields);
  if ($res->{noop}) {
    say "No changes for #$res->{id} $res->{name}";
    return;
  }
  my $prefix = $res->{dryrun} ? 'would set' : 'set';
  say(($res->{dryrun} ? 'dryrun ' : '') . "#$res->{id} $res->{name}");
  for my $k (sort keys $res->{changes}->%*) {
    my $ch  = $res->{changes}{$k};
    my $old = $ch->{old} // '';
    my $new = $ch->{new} // '';
    say "  $prefix $k:";
    say "    - $old" if length $old;
    say "    + $new" if length $new;
    say "    + (cleared)" if !length $new && length $old;
  }
}

# Support --description=text, --description=@file, --description=-
sub _read_text_opt {
  my ($v) = @_;
  return $v unless defined $v;
  if ($v eq '-') {
    local $/;
    my $t = <STDIN>;
    return defined $t ? $t : '';
  }
  if ($v =~ /^@(.*)\z/s) {
    my $path = $1;
    die "Error: empty path after @ in text option\n" unless length $path;
    open my $fh, '<:encoding(UTF-8)', $path
      or die "Error: cannot read $path: $!\n";
    local $/;
    my $t = <$fh>;
    close $fh;
    return defined $t ? $t : '';
  }
  return $v;
}

sub cmd_scan {
  my @args = @_;
  my ($dryrun, $force);
  my $usage = <<'USAGE';
Usage: 3dlib scan [options]

  Re-scan /share/3d and catalog anything not already in the database.

Options:
  --dryrun, --dry-run   Show what would be cataloged
  --force               Re-catalog paths already in the database
  -h, --help            Show this help
USAGE
  parse_opts(
    $usage, \@args,
    'dryrun|dry-run' => \$dryrun,
    'force'          => \$force,
  );
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  my $res = Import::scan_library(dryrun => $dryrun, force => $force);
  say "Cataloged ", scalar(@$res), " item(s)";
  for my $r (@$res) {
    say "  #$r->{item_id} $r->{kind} $r->{path}";
  }
}

sub cmd_query {
  my @args = @_;
  my $usage = <<'USAGE';
Usage: 3dlib query TEXT
       3dlib search TEXT

  Full-text search of names, descriptions, paths, and source URLs.

Options:
  -h, --help    Show this help
USAGE
  parse_opts($usage, \@args);

  my $q = join ' ', @args;
  die "Error: search text required.\nTry: 3dlib query --help\n" unless length $q;

  ensure_db();
  my $items = DB::search($q, 50);
  _print_items($items);
}

sub cmd_ls {
  my @args = @_;
  my %o;
  my $usage = <<'USAGE';
Usage: 3dlib ls [options]

  List catalog items (most recently modified first).

Options:
  --kind K        Filter by kind (file, project)
  --limit N       Max rows (default 100)
  --no-source     Only items missing a source URL
  --no-tags       Only items with no keywords/tags
  --no-thumb      Only items missing a thumbnail
  --status S      Filter by status (active, unsorted, ...)
  --tag T         Filter by keyword/tag (repeatable; AND)
  --type T        Filter by type (3mf, stl, step, fcstd, mixed, ...)
  -h, --help      Show this help
USAGE
  my @tags;
  parse_opts(
    $usage, \@args,
    'type=s'    => \$o{type},
    'kind=s'    => \$o{kind},
    'status=s'  => \$o{status},
    'no-thumb'  => \$o{no_thumb},
    'no-source' => \$o{no_source},
    'no-tags'   => \$o{no_tags},
    'tag=s'     => \@tags,
    'limit=i'   => \$o{limit},
  );
  $o{tags} = \@tags if @tags;
  die "Error: unexpected argument(s): @args\n" if @args;

  $o{limit} //= 100;
  ensure_db();
  my $items = DB::list_items(%o);
  _print_items($items);
}

sub cmd_describe {
  my @args = @_;
  my $view;
  my $usage = <<'USAGE';
Usage: 3dlib describe ID|PATH [options]

  Show full catalog details for one item (also: latest, latest-N).
  Use --view (or the show command) to open the thumbnail in an image viewer.

Options:
  --view            Open thumbnail after printing details
  --no-view         Never open viewer (default for describe)
  -h, --help        Show this help

Image viewer (for --view / show):
  THREEDLIB_IMAGE_VIEWER, config image_viewer, or tools.image_viewer
  Default: feh
USAGE
  parse_opts(
    $usage, \@args,
    'view!' => \$view,
  );

  my $id = shift @args
    // die "Error: ID or PATH required.\nTry: 3dlib describe --help\n";
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  my $item = Item::load($id) // die "Not found: $id\n";
  $item->describe_to(*STDOUT);
  _open_item_thumb($item->id) if $view;
}

sub cmd_show {
  my @args = @_;
  my $no_view;
  my $usage = <<'USAGE';
Usage: 3dlib show ID|PATH [options]
       3dlib inspect ID|PATH
       3dlib view ID|PATH

  Print catalog details for one item (also: latest, latest-N) and open its
  thumbnail in an image viewer (default: feh).  Generates a missing/stale
  thumb when possible.

Options:
  --no-view         Print details only (same as describe)
  --thumb-only      Open viewer without printing details
  -h, --help        Show this help

Image viewer:
  export THREEDLIB_IMAGE_VIEWER='feh -.'
  # or in config.json:  "image_viewer": "feh"
  # or:  "tools": { "image_viewer": "imv" }
USAGE
  my $thumb_only = 0;
  parse_opts(
    $usage, \@args,
    'no-view'    => \$no_view,
    'thumb-only' => \$thumb_only,
  );

  my $id = shift @args
    // die "Error: ID or PATH required.\nTry: 3dlib show --help\n";
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  my $item = Item::load($id) // die "Not found: $id\n";
  $item->describe_to(*STDOUT) unless $thumb_only;
  _open_item_thumb($item->id) unless $no_view;
}

# Ensure thumb exists if possible, then launch the configured image viewer.
sub _open_item_thumb {
  my ($id) = @_;
  require Thumbs;
  try {
    Thumbs::ensure_item_thumb($id);
  }
  catch ($e) {
    warn "thumb generate: $e\n";
  }

  my $row = DB::get_item($id) or die "Not found: $id\n";
  my $thumb = $row->{thumb_path};
  if (!$thumb || !-f $thumb) {
    my $cand = LibConfig::thumbs_dir() . "/$id.png";
    $thumb = $cand if -f $cand;
  }
  die "No thumbnail for #$id ($row->{name}). Try: 3dlib thumbs $id --force\n"
    unless $thumb && -f $thumb;

  my $viewer = LibConfig::image_viewer();
  # Allow extra args in the viewer string, e.g. "feh -." or "imv -f"
  my @cmd = split /\s+/, $viewer;
  @cmd = ('feh') unless @cmd;
  push @cmd, $thumb;

  say "viewer: @cmd";
  my $rc = system(@cmd);
  if ($rc == -1) {
    die "Failed to run image viewer '$viewer': $!\n"
      . "Install feh or set THREEDLIB_IMAGE_VIEWER / image_viewer in config.\n";
  }
  if ($rc != 0) {
    my $code = $rc >> 8;
    warn "Image viewer exited $code\n";
  }
  return 1;
}

sub cmd_thumbs {
  my @args = @_;
  my ($missing, $verbose, $force, $limit);
  my $usage = <<'USAGE';
Usage: 3dlib thumbs [ID|PATH]... [options]

  Generate thumbnails.  Tries in order:
    1) project images/
    2) embedded 3MF plate/cover previews
    3) mesh-preview render (STL, STEP, OBJ, 3MF, …)

  With no IDs: items whose thumb is missing OR older than the source file.
  With IDs/paths: only those items (still skips if thumb is up-to-date,
  unless --force).

Examples:
  3dlib thumbs -v                 # missing + outdated
  3dlib thumbs 3 --force          # always rebuild #3
  3dlib thumbs /share/3d/stl/x.stl --force -v
  3dlib thumbs --force            # rebuild ALL thumbs

Options:
  --force           Regenerate even if thumb is newer than the source
  --limit N         Max items when scanning the catalog (default 5000)
  --missing         Legacy alias (default already includes missing/stale)
  -h, --help        Show this help
  -v, --verbose     Print each item
USAGE
  parse_opts(
    $usage, \@args,
    'missing'   => \$missing,
    'force'     => \$force,
    'verbose|v' => \$verbose,
    'limit=i'   => \$limit,
  );

  ensure_db();
  my @ids;
  if (@args) {
    @ids = Thumbs::resolve_targets(@args);
    # Targeting specific items implies we want them updated;
    # --force overwrites existing files; without it, skips if present.
  }
  elsif ($missing && $force) {
    # explicit --missing wins over bare --force all
    $force = 0;
  }

  my $n = Thumbs::generate_missing(
    verbose => $verbose,
    force   => $force ? 1 : 0,
    limit   => $limit,
    ids     => @ids ? \@ids : undef,
  );
  say(($force ? "Refreshed" : "Generated"), " $n thumbnail(s)");
}

sub cmd_stats {
  my @args = @_;
  my $usage = <<'USAGE';
Usage: 3dlib stats

  Print catalog counts by kind/type and missing thumb/source tallies.

Options:
  -h, --help    Show this help
USAGE
  parse_opts($usage, \@args);
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  my $s = DB::stats();
  say "total:     $s->{total}";
  say "no_thumb:  $s->{no_thumb}";
  say "no_source: $s->{no_source}";
  say "by kind:";
  for my $r (@{ $s->{by_kind} }) {
    say "  $r->{kind}: $r->{c}";
  }
  say "by type:";
  for my $r (@{ $s->{by_type} }) {
    say "  $r->{type}: $r->{c}";
  }
}

sub cmd_run {
  my @args = @_;
  my ($dryrun, $no_import, $app);
  my $usage = <<'USAGE';
Usage: 3dlib run TARGET [options]
       3dlib open TARGET [options]

  Resolve TARGET, optionally import into /share/3d, then open in an app.
  Default app is Bambu Studio.  Desktop URL handlers call this command:

    3dlib run 'bambustudio://library/ID'
    3dlib run 'freecad://library/ID'

TARGET:
  local path, catalog ID, MakerWorld https URL,
  bambustudio://…, freecad://…, or 3dlib://studio|freecad/ID
  Recency (by mtime, newest first):
    latest          newest item
    latest-1        second newest
    latest-2        third newest  (also latest~1, new, new-1)

Options:
  --app studio|freecad  Application to launch (default: studio; freecad for .FCStd)
  --dryrun, --dry-run   Describe only; do not import or launch
  --no-import           Open without importing into the library
  -h, --help            Show this help

Register handlers (once per desktop session user):
  3dlib install-handler

FreeCAD config (config.json or env):
  freecad / THREEDLIB_FREECAD       e.g. "ssh -Y tomoon freecad" or "freecad"
  freecad_shell / THREEDLIB_FREECAD_SHELL=1   use /bin/sh -c for complex commands
  Use {file} in the command for the path, or it is appended as the last arg.
USAGE
  parse_opts(
    $usage, \@args,
    'dryrun|dry-run' => \$dryrun,
    'no-import'      => \$no_import,
    'app=s'          => \$app,
  );

  my $target = shift @args
    // die "Error: TARGET required.\nTry: 3dlib run --help\n";
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  Run::run(
    target    => $target,
    dryrun    => $dryrun ? 1 : 0,
    no_import => $no_import ? 1 : 0,
    app       => $app // 'studio',
  );
}

sub cmd_serve {
  my @args = @_;
  my ($port, $bind);
  my $usage = <<'USAGE';
Usage: 3dlib serve [options]

  Start the local web UI (gallery, item detail, STL viewer, Open in Studio).
  Ctrl-C stops; SIGHUP or SIGQUIT (Ctrl-\\) re-execs and reloads code.

Options:
  --bind ADDR   Bind address (default 0.0.0.0)
  --port N      Port (default 31353)
  -h, --help    Show this help
USAGE
  parse_opts(
    $usage, \@args,
    'port=i' => \$port,
    'bind=s' => \$bind,
  );
  die "Error: unexpected argument(s): @args\n" if @args;

  ensure_db();
  Web::serve(
    port   => $port,
    bind   => $bind,
    reexec => '/usr/local/bin/3dlib',
  );
}

sub cmd_install_handler {
  my @args = @_;
  my $usage = <<'USAGE';
Usage: 3dlib install-handler

  Install desktop entries and set 3dlib as the default handler for:
    x-scheme-handler/bambustudio   (MakerWorld + web "Open in Bambu Studio")
    x-scheme-handler/freecad       (web "Open in FreeCAD")
    x-scheme-handler/3dlib         (optional unified 3dlib://studio/ID)
    application/zip                (3D zips → library; others → download_dir)

  Handlers run in your desktop session (correct DISPLAY / xpra), then:
    3dlib run 'bambustudio://library/ID'
    3dlib run 'freecad://library/ID'
    3dlib import PATH              (zip / model file open)

  Restore Bambu Studio handler example:
    xdg-mime default OrcaSlicer.desktop x-scheme-handler/bambustudio

  Restore system zip handler example:
    xdg-mime default org.gnome.FileRoller.desktop application/zip

Options:
  -h, --help    Show this help
USAGE
  parse_opts($usage, \@args);
  die "Error: unexpected argument(s): @args\n" if @args;

  my $bambu = <<'EOF';
[Desktop Entry]
Name=3dlib (Bambu Studio)
Comment=Open library items / MakerWorld links via 3dlib then Bambu Studio
Exec=/usr/local/bin/3dlib run %u
Terminal=false
Type=Application
MimeType=model/stl;model/3mf;application/vnd.ms-3mfdocument;application/prs.wavefront-obj;application/x-amf;x-scheme-handler/bambustudio;x-scheme-handler/3dlib;
Categories=Graphics;3DGraphics;Engineering;
Keywords=3D;Printing;Slicer;Bambu;MakerWorld;3dlib
StartupNotify=false
NoDisplay=false
EOF

  my $freecad = <<'EOF';
[Desktop Entry]
Name=3dlib (FreeCAD)
Comment=Open FreeCAD library items via 3dlib
Exec=/usr/local/bin/3dlib run %u
Terminal=false
Type=Application
MimeType=application/x-extension-fcstd;application/x-freecad;x-scheme-handler/freecad;
Categories=Graphics;3DGraphics;Engineering;Science;
Keywords=3D;CAD;FreeCAD;FCStd;3dlib
StartupNotify=false
NoDisplay=false
EOF

  my $zip = <<'EOF';
[Desktop Entry]
Name=3dlib (Import zip)
Comment=Import 3D model zips into the library; non-3D zips go to download_dir
Exec=/usr/local/bin/3dlib import %f
Terminal=false
Type=Application
MimeType=application/zip;application/x-zip;application/x-zip-compressed;application/x-compressed-zip;
Categories=Graphics;3DGraphics;Utility;
Keywords=3D;Printing;zip;import;3dlib
StartupNotify=false
NoDisplay=false
EOF

  my $dir = ($ENV{HOME} // die "HOME not set\n") . '/.local/share/applications';
  make_path($dir);

  my @written;
  for my $pair (
    [ '3dlib-bambu.desktop',   $bambu ],
    [ '3dlib-freecad.desktop', $freecad ],
    [ '3dlib-zip.desktop',     $zip ],
  ) {
    my ($name, $body) = @$pair;
    my $path = "$dir/$name";
    open my $fh, '>', $path or die "Cannot write $path: $!\n";
    print {$fh} $body;
    close $fh;
    say "Wrote $path";
    push @written, $name;

    # Keep repo/system template in sync when the symlink tree exists
    my $ref = "/usr/local/3dlib/share/applications/$name";
    if (open my $fh2, '>', $ref) {
      print {$fh2} $body;
      close $fh2;
      say "Wrote $ref";
    }
  }

  system('update-desktop-database', $dir);

  my @schemes = (
    [ '3dlib-bambu.desktop',   'x-scheme-handler/bambustudio' ],
    [ '3dlib-bambu.desktop',   'x-scheme-handler/3dlib' ],
    [ '3dlib-freecad.desktop', 'x-scheme-handler/freecad' ],
    [ '3dlib-zip.desktop',     'application/zip' ],
    [ '3dlib-zip.desktop',     'application/x-zip-compressed' ],
  );
  for my $s (@schemes) {
    my ($desk, $mime) = @$s;
    my $rc = system('xdg-mime', 'default', $desk, $mime);
    if ($rc == 0) {
      say "Set default handler: $mime -> $desk";
    }
    else {
      say "To activate $mime:";
      say "  xdg-mime default $desk $mime";
    }
  }

  say "";
  say "Verify:";
  say "  xdg-mime query default x-scheme-handler/bambustudio";
  say "  xdg-mime query default x-scheme-handler/freecad";
  say "  xdg-mime query default application/zip";
  say "Test:";
  say "  3dlib run 'bambustudio://library/1'";
  say "  3dlib run 'freecad://library/1'";
  say "  xdg-open 'bambustudio://library/1'";
  say "  3dlib import /path/to/models.zip --dryrun";
}


sub cmd_repair_encoding {
  my @args = @_;
  my $usage = <<'USAGE';
Usage: 3dlib repair-encoding [--dryrun]

  Fix UTF-8 mojibake in catalog text fields (name, name_orig, path,
  description).  Safe to re-run.  Also runs automatically during scan.

Options:
  --dryrun, --dry-run   Show fixes only
  -h, --help            Show this help
USAGE
  my $dryrun;
  parse_opts($usage, \@args, 'dryrun|dry-run' => \$dryrun);
  die "Error: unexpected argument(s): @args\n" if @args;
  ensure_db();
  my $n = Import::repair_catalog_encoding(dryrun => $dryrun ? 1 : 0);
  say "Repaired $n item(s)";
}

sub cmd_translate {
  my @args = @_;
  my ($dryrun, $force, $verbose, $limit, $rename_files);
  my $usage = <<'USAGE';
Usage: 3dlib translate [ID|PATH]... [options]

  Translate non-English catalog names and descriptions to English via an
  OpenAI-compatible API (OpenAI ChatGPT or xAI Grok).

  Detects CJK, German/French/etc. (diacritics or common words), and other
  scripts.  Pure-ASCII German (no umlauts) is included via word heuristics.
  Originals are kept in name_orig / description_orig.
  description_orig is hidden in the web UI by default.

  By default also renames on-disk paths under the library to the English
  basename (project dirs and single files).  Import does this automatically
  when auto_import translation is enabled.

  Uses OPENAI_API_KEY by default (model gpt-4o-mini).  For Grok:
    export XAI_API_KEY=...
    and set in /share/3d/.library/config.json:
      "translate": { "provider": "xai", "model": "grok-3-mini" }

  Detection mode (config translate.detect):
    auto  — non-English including CJK + European languages (default)
    cjk   — Chinese/Japanese/Korean only (old behavior)

  With no IDs: translate all items still needing name/description/path work.

Examples:
  3dlib translate -v
  3dlib translate --dryrun
  3dlib translate 14 -v
  3dlib translate --force 8
  3dlib translate --no-rename-files

Options:
  --dryrun              Show what would be translated/renamed
  --force               Re-translate even if already done
  --limit N             Max items when scanning (default 5000)
  --rename-files        Rename on-disk paths to English (default)
  --no-rename-files     Catalog text only; leave filesystem paths alone
  -h, --help            Show this help
  -v, --verbose         Print each item
USAGE
  parse_opts(
    $usage, \@args,
    'force'            => \$force,
    'dryrun|dry-run'   => \$dryrun,
    'verbose|v'        => \$verbose,
    'limit=i'          => \$limit,
    'rename-files!'    => \$rename_files,
  );

  ensure_db();
  my @ids;
  @ids = Thumbs::resolve_targets(@args) if @args;

  my $n = Translate::translate_many(
    force        => $force ? 1 : 0,
    dryrun       => $dryrun ? 1 : 0,
    verbose      => $verbose ? 1 : 0,
    limit        => $limit,
    ids          => @ids ? \@ids : undef,
    rename_files => defined $rename_files ? ($rename_files ? 1 : 0) : 1,
  );
  say(($dryrun ? "Would translate/rename" : "Translated/renamed"), " $n item(s)");
}

sub cmd_help {
  my @args = @_;
  if (@args == 1 && $args[0] !~ /^-/ && $cmds{ $args[0] }) {
    $cmds{ $args[0] }->('--help');
    return;
  }
  if (@args) {
    my $usage = <<'USAGE';
Usage: 3dlib help [COMMAND]
       3dlib --help

  Show global help, or help for a subcommand (e.g. 3dlib help import).
USAGE
    parse_opts($usage, \@args);
  }

  print "3dlib - personal 3D model library under /share/3d\n\n";
  print "Usage:\n  3dlib <command> [options]\n\n";
  print "Commands:\n";
  for my $row (sort { $a->[0] cmp $b->[0] } @COMMAND_HELP) {
    printf "  %-18s %s\n", $row->[0], $row->[1];
  }
  print <<'EOF';

Aliases: rm=delete, search=query, list=ls, open=run, handler=install-handler,
         inspect=show, view=show, tags=tag, keyword=tag, keywords=tag

Run "3dlib <command> --help" for details on any command (options listed sorted).

Import defaults to MOVE into /share/3d (use --copy to leave source).
Delete also removes library files unless --keep-files.
--dryrun only describes actions; unknown options abort without changes.

Web UI: 3dlib serve   -> http://HOST:31353/

Full manual: man 3dlib
Source: /usr/local/3dlib
EOF
}

sub _print_items ($items) {
  DB::attach_tags($items) if $items;
  for my $row ($items->@*) {
    my \%it = $row;
    my $tags = $it{tags} && ref $it{tags} eq 'ARRAY' && $it{tags}->@*
      ? join(', ', $it{tags}->@*)
      : '';
    printf "#%-5d %-8s %-6s  %s\n  %s\n  mtime %s  %s\n",
      $it{id},
      $it{kind} // '',
      $it{type} // '',
      $it{name} // '',
      $it{path} // '',
      fmt_time($it{mtime}),
      $it{source_url} // '';
    say "  tags: $tags" if length $tags;
    say '';
  }
  say scalar($items->@*), " item(s)";
}

sub _print_results ($res, %o) {
  my $quiet = $o{quiet} // 0;
  $res = [$res] unless ref $res eq 'ARRAY';
  for my $row ($res->@*) {
    my \%r = $row;
    my $act = $r{action} // '?';
    my $id  = $r{item_id} // '-';
    say "[$act] #$id ", ($r{source} // ''), " -> ", ($r{dest} // '');
    say "        ", $r{reason} if $r{reason};

    next if $quiet;
    next unless defined $r{item_id} && $r{item_id} =~ /^\d+$/;

    my $it = eval { DB::get_item($r{item_id}) };
    if ($it) {
      _print_import_detail($it, \%r);
    }
    else {
      # Dry-run / pre-catalog fields from the import result itself
      for my $k (qw(name type source_url design_model_id)) {
        next unless defined $r{$k} && length $r{$k};
        printf "  %-12s %s\n", "$k:", $r{$k};
      }
    }
    say '';
  }
  say scalar($res->@*), " result(s)";
}

sub _print_import_detail {
  my ($it, $r) = @_;
  $r //= {};
  printf "  %-12s %s\n", 'name:',   $it->{name} // '';
  printf "  %-12s %s / %s\n", 'kind/type:', $it->{kind} // '', $it->{type} // ($r->{type} // '');
  printf "  %-12s %s\n", 'path:',   $it->{path} // ($r->{dest} // '');
  printf "  %-12s %s\n", 'status:', $it->{status} // '';
  if ($it->{tags} && $it->{tags}->@*) {
    printf "  %-12s %s\n", 'tags:', join(', ', $it->{tags}->@*);
  }
  if ($it->{source_url}) {
    printf "  %-12s %s\n", 'source:', $it->{source_url};
    printf "  %-12s %s\n", 'site:',   $it->{source_site}
      if $it->{source_site};
  }
  printf "  %-12s %s\n", 'design_id:', $it->{design_model_id}
    if $it->{design_model_id};
  printf "  %-12s %s\n", 'size:', human_size($it->{size_bytes})
    if defined $it->{size_bytes};
  printf "  %-12s %s\n", 'mtime:', fmt_time($it->{mtime})
    if $it->{mtime};

  my $thumb = $it->{thumb_path};
  if (!$thumb || !-f $thumb) {
    my $cand = LibConfig::thumbs_dir() . "/$it->{id}.png";
    $thumb = $cand if -f $cand;
  }
  printf "  %-12s %s\n", 'thumb:',
    ($thumb && -f $thumb) ? $thumb : '(none)';

  if (defined $it->{description} && length $it->{description}) {
    my $d = $it->{description};
    $d =~ s/\s+/ /g;
    $d = substr($d, 0, 200) . '…' if length $d > 200;
    printf "  %-12s %s\n", 'desc:', $d;
  }
  say "  (existing catalog entry)" if $r->{existing};
}

